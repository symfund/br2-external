config BR2_PACKAGE_TENSORFLOW_LITE
	bool "tensorflow-lite"
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	depends on BR2_TOOLCHAIN_GCC_AT_LEAST_9 # TFLite 2.21 requires modern GCC
	select BR2_PACKAGE_FLATBUFFERS
	select BR2_PACKAGE_EIGEN
	select BR2_PACKAGE_LIBABSEIL_CPP
	select BR2_PACKAGE_FARMHASH
	select BR2_PACKAGE_PROTOBUF
	select BR2_PACKAGE_FXDIV
	help
	  TensorFlow Lite is a set of tools to help developers run 
	  TensorFlow models on mobile, embedded, and IoT devices.

	  https://tensorflow.org

comment "tensorflow-lite needs a toolchain w/ C++, threads, gcc >= 9"
	depends on !BR2_INSTALL_LIBSTDCPP || !BR2_TOOLCHAIN_HAS_THREADS || !BR2_TOOLCHAIN_GCC_AT_LEAST_9

