
menu "User Provided Source"

config USR_ARM_TRUSTED_FIRMWARE_SRCDIR
        string "Arm Trusted Firmware source directory"
        default ""

config USR_UBOOT_SRCDIR
	string "U-Boot source directory"
	default ""

config USR_OPTEE_OS_SRCDIR
	string "optee-os source directory"
	default ""

config USR_LINUX_SRCDIR
	string "Linux source directory"
	default ""

endmenu

menu "TensorFlow Runtime Libraries"

